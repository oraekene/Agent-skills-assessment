{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unit Ranking Ledger",
  "type": "object",
  "required": ["version", "taxonomy_assignments", "tag_assignments", "score_records", "grouped_results"],
  "properties": {
    "version": { "type": "string" },
    "taxonomy_assignments": {
      "type": "array",
      "items": { "$ref": "#/$defs/taxonomyAssignment" }
    },
    "tag_assignments": {
      "type": "array",
      "items": { "$ref": "#/$defs/tagAssignment" }
    },
    "score_records": {
      "type": "array",
      "items": { "$ref": "#/$defs/scoreRecord" }
    },
    "grouped_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/groupedResult" }
    }
  },
  "$defs": {
    "taxonomyAssignment": {
      "type": "object",
      "required": ["assignment_id", "unit_id", "taxonomy_version", "primary_domain", "function_modes"],
      "properties": {
        "assignment_id": { "type": "string" },
        "unit_id": { "type": "string" },
        "taxonomy_version": { "type": "string" },
        "primary_domain": { "type": "string" },
        "hybrid_primary_members": {
          "type": "array",
          "items": { "type": "string" }
        },
        "secondary_domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "function_modes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "industry_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "role_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "context_scope_tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "tagAssignment": {
      "type": "object",
      "required": ["tag_assignment_id", "subject_type", "subject_id", "tag_family", "tag_id", "tag_label"],
      "properties": {
        "tag_assignment_id": { "type": "string" },
        "subject_type": { "type": "string" },
        "subject_id": { "type": "string" },
        "tag_family": { "type": "string" },
        "tag_id": { "type": "string" },
        "tag_label": { "type": "string" },
        "assignment_evidence_type": { "type": "string" },
        "assignment_basis": { "type": "string" }
      }
    },
    "scoreRecord": {
      "type": "object",
      "required": ["score_id", "subject_type", "subject_id", "score_family", "score_value", "score_band"],
      "properties": {
        "score_id": { "type": "string" },
        "subject_type": { "type": "string" },
        "subject_id": { "type": "string" },
        "score_family": { "type": "string" },
        "score_value": { "type": "number" },
        "score_band": { "type": "string" },
        "rubric_version": { "type": "string" },
        "evidence_coverage": { "type": "number" },
        "unknown_share": { "type": "number" }
      }
    },
    "groupedResult": {
      "type": "object",
      "required": ["result_id", "domain", "score_family", "bands"],
      "properties": {
        "result_id": { "type": "string" },
        "domain": { "type": "string" },
        "score_family": { "type": "string" },
        "bands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["band", "unit_ids"],
            "properties": {
              "band": { "type": "string" },
              "unit_ids": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
